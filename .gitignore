from quanser.multimedia import Video3D, Video3DStreamType, ImageFormat, ImageDataType
import numpy as np
import cv2

# 1. Initialize the RealSense camera (device "0" is typically the default)
camera = Video3D("0")

# 2. Configure stream parameters
stream_index = 0
frame_rate = 30.0
width, height = 640, 480

# 3. Open the RGB (Color) Stream
# Requesting BGR layout ensures native compatibility with OpenCV
color_stream = camera.stream_open(
    Video3DStreamType.COLOR,
    stream_index,
    frame_rate,
    width, height,
    ImageFormat.ROW_MAJOR_INTERLEAVED_BGR,
    ImageDataType.UINT8
)

# 4. Open the Depth Stream
# Depth is represented as a 16-bit greyscale matrix
depth_stream = camera.stream_open(
    Video3DStreamType.DEPTH,
    stream_index,
    frame_rate,
    width, height,
    ImageFormat.ROW_MAJOR_GREYSCALE,
    ImageDataType.UINT16
)

# Start pulling data from the hardware
camera.start_streaming()

# Allocate static NumPy arrays to hold the incoming pixel data
color_image = np.zeros((height, width, 3), dtype=np.uint8)
depth_image = np.zeros((height, width), dtype=np.uint16)

try:
    while True:
        # Get the latest frame handles from the stream
        color_frame = color_stream.get_frame()
        depth_frame = depth_stream.get_frame()
        
        # Read the raw pixel data into our pre-allocated NumPy arrays
        color_frame.get_data(color_image)
        depth_frame.get_data(depth_image)
        
        # Release the frames back to the buffer 
        color_frame.release()
        depth_frame.release()

        # --- Your object detection and distance logic goes here ---

        # Optional: Display the RGB view for debugging
        cv2.imshow("QBot RGB View", color_image)
        
        # Break the loop if the 'q' key is pressed
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
            
finally:
    # Safely shut down streams and close the device connection
    camera.stop_streaming()
    camera.close()
    cv2.destroyAllWindows()